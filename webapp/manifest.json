{
  "_version": "1.65.0",
  "sap.app": {
    "id": "abap.to.fiori.system",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "1.0.0"
    },
    "title": "ABAP to Fiori Modernization Cockpit",
    "description": "SAPUI5 Freestyle app consuming the ABAP Migration Analyzer OData V4 service.",
    "dataSources": {
      "mainService": {
        "uri": "/sap/opu/odata4/sap/zui_analyzer_odata/srvd/sap/zui_analyzer_service/0001/",
        "type": "OData",
        "settings": {
          "odataVersion": "4.0"
        }
      }
    },
    "crossNavigation": {
      "inbounds": {
        "display": {
          "semanticObject": "ABAPMigrationAnalyzer",
          "action": "display",
          "title": "ABAP to Fiori Modernization Cockpit",
          "signature": {
            "parameters": {},
            "additionalParameters": "allowed"
          }
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "sap-icon://business-objects-experience"
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "rootView": {
      "viewName": "abap.to.fiori.system.view.App",
      "type": "XML",
      "id": "app",
      "async": true
    },
    "dependencies": {
      "minUI5Version": "1.120.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.f": {},
        "sap.ui.layout": {},
        "sap.ui.table": {},
        "sap.ui.comp": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "": {
        "dataSource": "mainService",
        "type": "sap.ui.model.odata.v4.ODataModel",
        "settings": {
          "operationMode": "Server",
          "synchronizationMode": "None",
          "autoExpandSelect": true,
          "earlyRequests": true,
          "groupId": "$auto",
          "updateGroupId": "$auto"
        }
      }
    },
    "resources": {
      "css": [
        {
          "uri": "css/style.css"
        }
      ]
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "type": "View",
        "viewType": "XML",
        "path": "abap.to.fiori.system.view",
        "controlId": "app",
        "controlAggregation": "pages",
        "async": true,
        "bypassed": {
          "target": "dashboard"
        }
      },
      "routes": [
        {
          "name": "dashboard",
          "pattern": "",
          "target": "dashboard"
        },
        {
          "name": "detail",
          "pattern": "detail/{programName*}",
          "target": "detail"
        }
      ],
      "targets": {
        "dashboard": {
          "viewName": "Dashboard"
        },
        "detail": {
          "viewName": "Detail"
        }
      }
    }
  },
  "sap.fiori": {
    "registrationIds": [],
    "archeType": "analytical"
  }
}
