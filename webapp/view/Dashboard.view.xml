<mvc:View
  controllerName="abap.to.fiori.system.controller.Dashboard"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  displayBlock="true"
>
  <mvc:dependents>
    <Dialog
      id="newAnalysisDialog"
      title="New Analysis"
      stretchOnPhone="true"
    >
      <content>
        <VBox class="sapUiMediumMargin">
          <Label text="Target Program Name:" labelFor="newAnalysisProgramInput" />
          <Input
            id="newAnalysisProgramInput"
            width="20rem"
            value="{view>/newAnalysis/programName}"
            submit=".onCreateNewAnalysis"
          />
        </VBox>
      </content>
      <beginButton>
        <Button
          text="New Analysis"
          type="Emphasized"
          busy="{view>/newAnalysis/busy}"
          press=".onCreateNewAnalysis"
        />
      </beginButton>
      <endButton>
        <Button text="Cancel" press=".onCancelNewAnalysis" />
      </endButton>
    </Dialog>
  </mvc:dependents>

  <Page
    id="dashboardPage"
    showHeader="false"
    busy="{view>/busy}"
    busyIndicatorDelay="0"
    class="cockpitEclipseDashboard"
  >
    <content>
      <!-- Header/filter area follows the Fiori list report style generated in Eclipse/ADT. -->
      <VBox class="cockpitEclipseFilterShell">
        <OverflowToolbar design="Transparent" class="cockpitEclipseVariantBar">
          <Title text="Standard" level="H2" class="cockpitEclipseVariantTitle" />
          <Text text="*" class="cockpitEclipseVariantDirty" />
          <Button icon="sap-icon://slim-arrow-down" type="Transparent" tooltip="Select Variant" />
          <ToolbarSpacer />
          <Button icon="sap-icon://action" type="Transparent" tooltip="Share" />
          <Button icon="sap-icon://slim-arrow-down" type="Transparent" tooltip="More Actions" />
        </OverflowToolbar>

        <HBox alignItems="End" justifyContent="SpaceBetween" wrap="Wrap" class="cockpitEclipseFilterContent">
          <VBox>
            <Label text="Program Name:" labelFor="programInput" />
            <SearchField
              id="programInput"
              width="26.5rem"
              value="{view>/selectedProgram}"
              placeholder="Enter Program Name"
              search=".onAnalyze"
            />
          </VBox>

          <HBox alignItems="Center" class="cockpitEclipseFilterActions">
            <Button text="Go" type="Emphasized" press=".onAnalyze" />
            <Button text="Adapt Filters (1)" type="Transparent" press=".onAdaptFilters" />
          </HBox>
        </HBox>

        <HBox justifyContent="Center" class="cockpitEclipseHeaderToggle">
          <Button icon="sap-icon://navigation-up-arrow" type="Transparent" tooltip="Collapse Header" />
          <Button icon="sap-icon://pushpin-on" type="Transparent" tooltip="Pin Header" />
        </HBox>
      </VBox>

      <!-- Program analysis table mirrors the Eclipse-generated Fiori preview layout. -->
      <VBox class="cockpitEclipseTableShell">
        <OverflowToolbar design="Transparent">
          <Title text="Program Analysis ({view>/analysisCount})" level="H3" />
          <ToolbarSpacer />
          <Button text="New Analysis" type="Transparent" press=".onOpenNewAnalysis" />
          <Button
            text="Delete"
            type="Transparent"
            enabled="{= ${view>/selectedReportCount} > 0 }"
            press=".onDeleteSelectedReports"
          />
          <Button icon="sap-icon://action-settings" type="Transparent" tooltip="Settings" />
          <Button icon="sap-icon://excel-attachment" type="Transparent" tooltip="Export" />
          <Button icon="sap-icon://slim-arrow-down" type="Transparent" tooltip="More" />
        </OverflowToolbar>

        <Table
          id="analysisTable"
          sticky="ColumnHeaders"
          growing="true"
          growingScrollToLoad="true"
          mode="MultiSelect"
          selectionChange=".onReportSelectionChange"
          itemPress=".onTableRowPress"
          noDataText="{view>/analysisNoDataText}"
          items="{view>/analysisRows}"
          class="cockpitEclipseAnalysisTable"
        >
          <columns>
            <Column width="18rem"><Text text="Program Name" /></Column>
            <Column width="22rem"><Text text="Description" /></Column>
            <Column width="7rem" hAlign="End"><Text text="Total Tables" /></Column>
            <Column width="7rem" hAlign="End"><Text text="Total Filters" /></Column>
            <Column width="9rem" hAlign="End"><Text text="Business Objects" /></Column>
            <Column width="8rem" hAlign="End"><Text text="Migration Sc..." /></Column>
            <Column width="8rem" hAlign="End"><Text text="Complexity ..." /></Column>
            <Column width="8rem" hAlign="End"><Text text="Cloud Readi..." /></Column>
            <Column width="14rem"><Text text="Analysis Status" /></Column>
          </columns>
          <items>
            <ColumnListItem type="Navigation" press=".onTableRowPress">
              <cells>
                <Link text="{view>ProgramName}" press=".onTableRowPress" />
                <Text text="{view>ProgramDescription}" />
                <ObjectNumber number="{view>TotalTables}" />
                <ObjectNumber number="{view>TotalFilters}" />
                <ObjectNumber number="{view>TotalBusinessObjects}" />
                <ObjectNumber number="{view>MigrationScore}" />
                <ObjectNumber number="{view>ComplexityScore}" />
                <ObjectNumber number="{view>CloudReadinessScore}" />
                <ObjectStatus
                  text="{path: 'view>AnalysisStatus', formatter: '.formatter.formatStatusText'}"
                  state="{
                    parts: [
                      {path: 'view>AnalysisStatus'},
                      {path: 'view>AnalysisStatusCriticality'}
                    ],
                    formatter: '.formatter.formatStatusState'
                  }"
                  icon="{
                    parts: [
                      {path: 'view>AnalysisStatus'},
                      {path: 'view>AnalysisStatusCriticality'}
                    ],
                    formatter: '.formatter.formatStatusIcon'
                  }"
                />
              </cells>
            </ColumnListItem>
          </items>
        </Table>
      </VBox>
    </content>
  </Page>
</mvc:View>
